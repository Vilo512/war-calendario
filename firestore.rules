rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /cleaning_schedule/{scheduleId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
