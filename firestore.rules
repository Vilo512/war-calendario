rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función helper para verificar si es admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@warcalendario.com';
    }

    match /bookings/{bookingId} {
      // Cualquiera autenticado puede leer las reservas
      allow read: if request.auth != null;
      // Para crear, debe estar autenticado y el userId debe coincidir
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Para actualizar/borrar, debe ser el dueño o el admin
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    // Resto de colecciones cerradas por defecto o de solo lectura si aplica
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
